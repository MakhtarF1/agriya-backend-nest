{
  "compilerOptions": {
    "module": "commonjs",
    "target": "ES2021",
    "outDir": "./dist",
    "baseUrl": ".",
    "ignoreDeprecations": "6.0",

    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,

    "allowSyntheticDefaultImports": true,
    "sourceMap": true,
    "declaration": true,
    "removeComments": true,

    "incremental": true,
    "skipLibCheck": true,
    "strict": false,
    "noImplicitAny": false,

    "types": ["node", "jest"],

    "paths": {
      "src/*": ["src/*"]
    }
  },
  "include": ["src/**/*.ts", "test/**/*.ts", "prisma/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
